<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Material - LearnClass</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f2f2f2;
        }

        .topbar {
            height: 64px;
            background: #62b9e8;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 26px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 24px;
            font-weight: 700;
            color: #111;
        }

        .brand img {
            width: 32px;
            height: 32px;
        }

        .container {
            max-width: 760px;
            margin: 40px auto;
            padding: 0 20px;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-volver {
            text-decoration: none;
            color: #3498db;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 15px;
        }

        .titulo-materia {
            font-size: 26px;
            font-weight: 800;
            color: #111;
        }

        .card {
            background: white;
            border-radius: 14px;
            padding: 26px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
        }

        .card h3 {
            font-size: 13px;
            font-weight: 700;
            color: #a0aec0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 16px;
            padding-bottom: 10px;
            border-bottom: 1px solid #f0f0f0;
        }

        .material-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px;
            border: 1px solid #edf2f7;
            border-radius: 10px;
            margin-bottom: 10px;
            transition: all 0.2s;
        }

        .material-item:hover {
            border-color: #3498db;
            background: #f0f7ff;
        }

        .material-info {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .material-icon {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        .icon-pdf {
            background: #fff5f5;
            color: #e53e3e;
        }

        .icon-zip {
            background: #fffbeb;
            color: #d69e2e;
        }

        .icon-doc {
            background: #ebf8ff;
            color: #3182ce;
        }

        .icon-img {
            background: #f0fff4;
            color: #38a169;
        }

        .icon-default {
            background: #f7fafc;
            color: #718096;
        }

        .material-datos strong {
            display: block;
            font-size: 15px;
            color: #2d3748;
        }

        .material-datos span {
            font-size: 12px;
            color: #a0aec0;
        }

        .btn-descargar {
            background: #111;
            color: white;
            border: none;
            border-radius: 8px;
            padding: 8px 16px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: background 0.2s;
        }

        .btn-descargar:hover {
            background: #333;
        }

        .empty {
            text-align: center;
            color: #a0aec0;
            padding: 40px 0;
        }

        .empty i {
            font-size: 36px;
            display: block;
            margin-bottom: 10px;
        }
    </style>
</head>

<body>
    <header class="topbar">
        <div class="brand">
            <img src="/afbbf15d5e82a1c4fb5a55c4eacf3003-icono-de-gorro-de-graduacion.png" alt="LearnClass">
            LearnClass
        </div>
    </header>

    <div class="container">
        <div class="header">
            <a href="/mis-asignaturas" class="btn-volver">
                <i class="fa-solid fa-arrow-left"></i> Volver
            </a>
            <span class="titulo-materia" id="tituloMateria">Cargando...</span>
        </div>

        <div class="card">
            <h3>Material disponible</h3>
            <div id="listaMaterial">
                <div class="empty">
                    <i class="fa-solid fa-spinner fa-spin"></i>
                    Cargando material...
                </div>
            </div>
        </div>
    </div>

    <script>
        const token = localStorage.getItem('token');
        if (!token) window.location.href = '/login';

        const materiaId = window.location.pathname.split('/').pop();

        function getIcono(nombre) {
            const ext = nombre.split('.').pop().toLowerCase();
            if (ext === 'pdf') return '<i class="fa-solid fa-file-pdf"></i>';
            if (['zip', 'rar'].includes(ext)) return '<i class="fa-solid fa-file-zipper"></i>';
            if (['doc', 'docx'].includes(ext)) return '<i class="fa-solid fa-file-word"></i>';
            if (['ppt', 'pptx'].includes(ext)) return '<i class="fa-solid fa-file-powerpoint"></i>';
            if (['xls', 'xlsx'].includes(ext)) return '<i class="fa-solid fa-file-excel"></i>';
            if (['png', 'jpg', 'jpeg'].includes(ext)) return '<i class="fa-solid fa-file-image"></i>';
            return '<i class="fa-solid fa-file"></i>';
        }

        function getIconClass(nombre) {
            const ext = nombre.split('.').pop().toLowerCase();
            if (ext === 'pdf') return 'icon-pdf';
            if (['zip', 'rar'].includes(ext)) return 'icon-zip';
            if (['doc', 'docx', 'ppt', 'pptx', 'xls', 'xlsx'].includes(ext)) return 'icon-doc';
            if (['png', 'jpg', 'jpeg'].includes(ext)) return 'icon-img';
            return 'icon-default';
        }

        async function cargarMaterial() {
            try {
                // Cargar nombre de la materia
                const resMat = await fetch('/materias/mis-materias-alumno', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const dataMat = await resMat.json();
                const materia = dataMat.materias.find(m => m._id === materiaId);
                if (materia) document.getElementById('tituloMateria').innerText = materia.nombre;

                // Cargar material
                const res = await fetch(`/materias/material?materiaId=${materiaId}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const data = await res.json();
                const lista = document.getElementById('listaMaterial');

                if (res.ok && data.materiales.length > 0) {
                    lista.innerHTML = data.materiales.map(m => `
                        <div class="material-item">
                            <div class="material-info">
                                <div class="material-icon ${getIconClass(m.archivo)}">
                                    ${getIcono(m.archivo)}
                                </div>
                                <div class="material-datos">
                                    <strong>${m.nombre}</strong>
                                    <span>${new Date(m.createdAt).toLocaleDateString('es-ES')} · ${m.archivo.split('.').pop().toUpperCase()}</span>
                                </div>
                            </div>
                            <a href="/${m.archivo}" target="_blank" class="btn-descargar">
                                <i class="fa-solid fa-download"></i>
                                Descargar
                            </a>
                        </div>
                    `).join('');
                } else {
                    lista.innerHTML = `
                        <div class="empty">
                            <i class="fa-solid fa-folder-open"></i>
                            El profesor aún no ha subido material
                        </div>
                    `;
                }
            } catch (err) {
                console.error(err);
            }
        }
        cargarMaterial();
    </script>
</body>

</html>