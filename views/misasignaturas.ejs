<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mis Asignaturas - LearnClass</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f2f2f2;
            padding: 40px 20px;
        }

        .topbar {
            height: 64px;
            background: #62b9e8;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 26px;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 100;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 24px;
            font-weight: 700;
            color: #111;
        }

        .brand img {
            width: 32px;
            height: 32px;
        }

        .container {
            max-width: 860px;
            margin: 90px auto 0;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 28px;
        }

        .btn-volver {
            text-decoration: none;
            color: #3498db;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 15px;
        }

        h1 {
            font-size: 28px;
            font-weight: 700;
            color: #111;
        }

        .materias-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 20px;
        }

        .materia-card {
            background: white;
            border-radius: 14px;
            padding: 24px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            cursor: pointer;
            transition: all 0.2s;
            border: 2px solid transparent;
        }

        .materia-card:hover {
            border-color: #3498db;
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(52, 152, 219, 0.15);
        }

        .materia-icono {
            width: 52px;
            height: 52px;
            background: #ebf5fb;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin-bottom: 14px;
            color: #3498db;
        }

        .materia-card h3 {
            font-size: 17px;
            font-weight: 700;
            color: #111;
            margin-bottom: 6px;
        }

        .materia-card p {
            font-size: 13px;
            color: #718096;
        }

        .materia-card .ver-material {
            margin-top: 16px;
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            font-weight: 600;
            color: #3498db;
        }

        .empty {
            text-align: center;
            color: #a0aec0;
            padding: 60px 0;
        }

        .empty i {
            font-size: 48px;
            display: block;
            margin-bottom: 14px;
        }
    </style>
</head>

<body>
    <header class="topbar">
        <div class="brand">
            <img src="/afbbf15d5e82a1c4fb5a55c4eacf3003-icono-de-gorro-de-graduacion.png" alt="LearnClass">
            LearnClass
        </div>
    </header>

    <div class="container">
        <div class="header">
            <a href="/dashboardalumno" class="btn-volver">
                <i class="fa-solid fa-arrow-left"></i> Volver
            </a>
            <h1>Mis materias</h1>
        </div>

        <div class="materias-grid" id="materiasGrid">
            <div class="empty">
                <i class="fa-solid fa-spinner fa-spin"></i>
                Cargando materias...
            </div>
        </div>
    </div>

    <script>
        const token = localStorage.getItem('token');
        if (!token) window.location.href = '/login';

        async function cargarMaterias() {
            try {
                const res = await fetch('/materias/mis-materias-alumno', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const data = await res.json();
                const grid = document.getElementById('materiasGrid');

                if (res.ok && data.materias.length > 0) {
                    grid.innerHTML = data.materias.map(m => `
                        <div class="materia-card" onclick="window.location.href='/asignatura/${m._id}'">
                            <div class="materia-icono">
                                <i class="fa-solid fa-book"></i>
                            </div>
                            <h3>${m.nombre}</h3>
                            <p>${m.descripcion || 'Sin descripción'}</p>
                            <div class="ver-material">
                                <i class="fa-solid fa-folder-open"></i>
                                Ver material
                            </div>
                        </div>
                    `).join('');
                } else {
                    grid.innerHTML = `
                        <div class="empty">
                            <i class="fa-solid fa-book-open"></i>
                            No estás matriculado en ninguna materia
                        </div>
                    `;
                }
            } catch (err) {
                console.error(err);
            }
        }
        cargarMaterias();
    </script>
</body>

</html>